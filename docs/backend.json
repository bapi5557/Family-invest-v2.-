
{
  "entities": {
    "Invite": {
      "title": "Family Invite",
      "description": "A secure code to invite members to a family ledger.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "10-digit numeric invite code (e.g., 1234567890)." },
        "ownerId": { "type": "string", "description": "The UID of the family owner who created the invite." },
        "expiresAt": { "type": "number", "description": "Timestamp of expiration (default 7 days)." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." },
        "revoked": { "type": "boolean", "description": "Whether the admin has revoked the code." }
      },
      "required": ["code", "ownerId", "expiresAt", "createdAt"]
    },
    "FamilyMember": {
      "title": "Family Member",
      "description": "A profile for a family member within the network.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The member's full name." },
        "phone": { "type": "string", "description": "The member's contact number." },
        "notes": { "type": "string", "description": "Additional notes about the member." },
        "photoUrl": { "type": "string", "description": "URL to the member's profile photo." },
        "ownerId": { "type": "string", "description": "The UID of the shared family account owner." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A record of a household expense.",
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "description": "The type of expense. Can be a default enum or custom string."
        },
        "amount": { "type": "number", "description": "The cost of the expense." },
        "description": { "type": "string", "description": "Details about the purchase." },
        "date": { "type": "number", "description": "Date of expense (timestamp)." },
        "memberId": { "type": "string", "description": "Reference to a family member." },
        "ownerId": { "type": "string", "description": "The UID of the shared family account owner." },
        "createdAt": { "type": "number", "description": "Timestamp of record creation." }
      },
      "required": ["category", "amount", "date", "ownerId", "createdAt"]
    },
    "Income": {
      "title": "Income",
      "description": "A record of household income.",
      "type": "object",
      "properties": {
        "source": { "type": "string", "description": "Source of income (e.g., Salary, Bonus)." },
        "amount": { "type": "number", "description": "Amount received." },
        "date": { "type": "number", "description": "Date of receipt." },
        "ownerId": { "type": "string", "description": "The UID of the shared family account owner." },
        "createdAt": { "type": "number", "description": "Timestamp of record creation." }
      },
      "required": ["source", "amount", "date", "ownerId", "createdAt"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A household or personal reminder.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the reminder." },
        "description": { "type": "string", "description": "Detailed notes." },
        "date": { "type": "number", "description": "The scheduled date (timestamp)." },
        "time": { "type": "string", "description": "Scheduled time." },
        "category": {
          "type": "string",
          "enum": ["Bill Payment", "Loan EMI", "Investment", "Insurance Renewal", "SIP/Mutual Fund", "Family Event", "Birthday", "Anniversary", "Other"],
          "description": "Reminder classification."
        },
        "priority": {
          "type": "string",
          "enum": ["Low", "Medium", "High"],
          "description": "Urgency level."
        },
        "isRecurring": { "type": "boolean" },
        "recurringType": {
          "type": "string",
          "enum": ["None", "Daily", "Weekly", "Monthly", "Yearly"]
        },
        "isGlobal": { "type": "boolean" },
        "completed": { "type": "boolean" },
        "ownerId": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "date", "category", "priority", "ownerId"]
    },
    "FamilySettings": {
      "title": "Family Settings",
      "description": "Global settings for a family account. Document ID matches the user UID. This document establishes family membership.",
      "type": "object",
      "properties": {
        "adminPin": { "type": "string", "description": "4-digit PIN for sensitive family actions." },
        "familyName": { "type": "string", "description": "The name of the family." },
        "ownerId": { "type": "string", "description": "The UID of the user who owns this settings profile." },
        "canExport": { "type": "boolean", "description": "Whether non-admin members can export data." },
        "familyOwnerId": { "type": "string", "description": "The UID of the parent family account if this user is a member." },
        "updatedAt": { "type": "number", "description": "Last updated timestamp." }
      },
      "required": ["adminPin", "ownerId"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A family activity notification. Shared among family members who share the same ownerId. Members can hide notifications locally via the hiddenBy field.",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "details": { "type": "string" },
        "type": { "type": "string", "enum": ["expense", "member", "reminder", "system"] },
        "timestamp": { "type": "number" },
        "ownerId": { "type": "string" },
        "readBy": { "type": "array", "items": { "type": "string" } },
        "hiddenBy": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "createdByName": { "type": "string" }
      },
      "required": ["message", "type", "timestamp", "ownerId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "FamilyMember",
      "description": "Collection of family members. Restricted by ownerId."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of household expenses. Restricted by ownerId."
    },
    "/income/{incomeId}": {
      "schema": "Income",
      "description": "Collection of household income records. Restricted by ownerId."
    },
    "/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "Collection of family reminders. Restricted by ownerId."
    },
    "/settings/{userId}": {
      "schema": "FamilySettings",
      "description": "User family configuration. Only matching UID can read/write."
    },
    "/invites/{inviteId}": {
      "schema": "Invite",
      "description": "Family invites. Read access is allowed by code for authenticated users to facilitate joining."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Family activity notifications. Shared access for read/write among family based on ownerId. (Security Rules: Enabled list for family members)"
    }
  }
}
